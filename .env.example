# Copy this to .env and fill in your values
# NEVER commit .env to git

SECRET_KEY=your-super-secret-50-character-key-goes-here-change-this
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# For production, set this to your PostgreSQL connection string:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Example Render.com PostgreSQL URL format:
# DATABASE_URL=postgresql://ojt_user:xxx@dpg-xxx.frankfurt-postgres.render.com/ojt_tracker
